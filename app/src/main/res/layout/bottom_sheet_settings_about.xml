<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="@dimen/dimen24dp"
    android:paddingBottom="@dimen/dimen32dp">

    <com.google.android.material.bottomsheet.BottomSheetDragHandleView
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <com.google.android.material.card.MaterialCardView
        style="?attr/materialCardViewFilledStyle"
        android:layout_width="@dimen/dimen72dp"
        android:layout_height="@dimen/dimen72dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="@dimen/dimen8dp"
        app:cardBackgroundColor="@color/colorPrimaryDark"
        app:cardCornerRadius="@dimen/dimen24dp"
        app:strokeWidth="0dp">

        <ImageView
            android:id="@+id/appLogo"
            android:layout_width="@dimen/dimen96dp"
            android:layout_height="@dimen/dimen96dp"
            android:layout_gravity="center_horizontal|center_vertical"
            android:src="@drawable/app_logo_monochrome" />

    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="@dimen/dimen12dp"
        android:text="@string/appName"
        android:textAppearance="@style/TextAppearance.Material3.HeadlineMedium"
        android:textStyle="bold" />

    <com.google.android.material.card.MaterialCardView
        style="?attr/materialCardViewFilledStyle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="@dimen/dimen8dp"
        app:cardBackgroundColor="?attr/colorSurfaceContainerHighest"
        app:cardCornerRadius="@dimen/dimen24dp"
        app:strokeWidth="0dp">

        <TextView
            android:id="@+id/appVersionBuild"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="@dimen/dimen12dp"
            android:paddingVertical="@dimen/dimen4dp"
            android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
            android:textColor="?attr/primaryTextColor" />

    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        style="?attr/materialCardViewFilledStyle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen24dp"
        app:cardBackgroundColor="?attr/materialCardBackgroundColor"
        app:cardCornerRadius="@dimen/dimen24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/dimen16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/commitPage"
                android:textAppearance="@style/TextAppearance.Material3.TitleSmall"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/userServerVersion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen4dp"
                android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                android:alpha="0.8"
                android:textIsSelectable="true" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen16dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/donationLinkPatreon"
            style="@style/Widget.Material3.Button"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="@dimen/dimen56dp"
            android:layout_marginEnd="@dimen/dimen4dp"
            android:backgroundTint="?attr/iconsColor"
            android:text="@string/supportTextPatreon"
            app:icon="@drawable/ic_patreon" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/appWebsite"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="@dimen/dimen56dp"
            android:layout_marginStart="@dimen/dimen4dp"
            android:text="@string/websiteText"
            app:icon="@drawable/ic_browser" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen8dp"
        android:gravity="center"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/translateLink"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/translateWithCrowdin"
            android:textColor="?attr/primaryTextColor"
            app:iconTint="?attr/primaryTextColor"
            app:icon="@drawable/ic_language" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/feedback"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/feedbackText"
            android:textColor="?attr/primaryTextColor"
            app:iconTint="?attr/primaryTextColor"
            android:visibility="gone"
            app:icon="@drawable/ic_feedback" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginVertical="@dimen/dimen20dp"
        android:background="?attr/colorOutlineVariant" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/dimen12dp"
        android:text="@string/discover_apps"
        android:textAppearance="@style/TextAppearance.Material3.TitleSmall"
        android:textColor="?attr/primaryTextColor" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_horizontal">

        <include android:id="@+id/appLabNex" layout="@layout/item_settings_more_apps" />
        <include android:id="@+id/appOceanNex" layout="@layout/item_settings_more_apps" />
        <include android:id="@+id/appNexNode" layout="@layout/item_settings_more_apps" />

    </LinearLayout>

</LinearLayout>
