<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.listitem.ListItemLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <com.google.android.material.listitem.ListItemCardView
        android:id="@+id/card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:checkable="false"
        android:layout_marginVertical="@dimen/dimen1dp"
        app:strokeWidth="0dp"
        app:cardBackgroundColor="?attr/materialCardBackgroundColor">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="@dimen/dimen8dp">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/repoAvatar"
                android:layout_width="@dimen/dimen40dp"
                android:layout_height="@dimen/dimen40dp"
                android:padding="@dimen/dimen4dp"
                android:background="@android:color/transparent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Small" />

            <TextView
                android:id="@+id/userId"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/dimen16dp"
                android:layout_marginEnd="@dimen/dimen8dp"
                android:textColor="?attr/primaryTextColor"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toStartOf="@+id/actionFrame"
                app:layout_constraintStart_toEndOf="@+id/repoAvatar"
                app:layout_constraintTop_toTopOf="@+id/repoAvatar" />

            <TextView
                android:id="@+id/accountUrl"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/dimen8dp"
                android:textSize="13sp"
                app:layout_constraintBottom_toBottomOf="@+id/repoAvatar"
                app:layout_constraintEnd_toStartOf="@+id/actionFrame"
                app:layout_constraintStart_toStartOf="@+id/userId"
                app:layout_constraintTop_toBottomOf="@+id/userId" />

            <FrameLayout
                android:id="@+id/actionFrame"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <ImageView
                    android:id="@+id/activeAccount"
                    android:layout_width="@dimen/dimen24dp"
                    android:layout_height="@dimen/dimen24dp"
                    android:contentDescription="@string/generalImgContentText"
                    android:src="@drawable/ic_check"
                    app:tint="?attr/colorPrimary"
                    android:visibility="gone" />

                <ImageView
                    android:id="@+id/deleteAccount"
                    android:layout_width="@dimen/dimen24dp"
                    android:layout_height="@dimen/dimen24dp"
                    android:padding="@dimen/dimen2dp"
                    android:contentDescription="@string/menuDeleteText"
                    android:src="@drawable/ic_delete"
                    app:tint="?attr/colorError"
                    android:visibility="gone" />

            </FrameLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.listitem.ListItemCardView>

</com.google.android.material.listitem.ListItemLayout>
