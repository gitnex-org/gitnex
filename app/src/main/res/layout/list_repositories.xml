<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.listitem.ListItemLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <com.google.android.material.listitem.ListItemCardView
        android:id="@+id/card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:checkable="false"
        app:strokeWidth="0dp"
        android:layout_marginVertical="@dimen/dimen1dp"
        app:cardBackgroundColor="?attr/materialCardBackgroundColor">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="@dimen/dimen8dp">

            <LinearLayout
                android:id="@+id/topStatsRow"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                app:layout_constraintEnd_toStartOf="@id/repoLastUpdated"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <ImageView
                    android:layout_width="@dimen/dimen14dp"
                    android:layout_height="@dimen/dimen14dp"
                    android:contentDescription="@string/generalImgContentText"
                    app:srcCompat="@drawable/ic_issue"
                    app:tint="?attr/iconsColor" />

                <TextView
                    android:id="@+id/repoOpenIssues"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/dimen4dp"
                    android:textAppearance="?attr/textAppearanceLabelMedium" />

                <ImageView
                    android:layout_width="@dimen/dimen14dp"
                    android:layout_height="@dimen/dimen14dp"
                    android:layout_marginStart="@dimen/dimen12dp"
                    android:contentDescription="@string/generalImgContentText"
                    app:srcCompat="@drawable/ic_pull_request"
                    app:tint="?attr/iconsColor" />

                <TextView
                    android:id="@+id/repoOpenPRs"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/dimen4dp"
                    android:textAppearance="?attr/textAppearanceLabelMedium" />

            </LinearLayout>

            <TextView
                android:id="@+id/repoLastUpdated"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceLabelLarge"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:alpha="0.8"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/imageAvatar"
                android:layout_width="@dimen/dimen36dp"
                android:layout_height="@dimen/dimen36dp"
                android:layout_marginTop="@dimen/dimen12dp"
                android:src="@drawable/ic_loader"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/topStatsRow"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Small" />

            <TextView
                android:id="@+id/orgName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/dimen10dp"
                android:alpha="0.8"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                app:layout_constraintBottom_toBottomOf="@id/imageAvatar"
                app:layout_constraintStart_toEndOf="@id/imageAvatar"
                app:layout_constraintTop_toTopOf="@id/imageAvatar" />

            <ImageView
                android:id="@+id/repo_is_archived_frame"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:layout_marginStart="@dimen/dimen8dp"
                android:contentDescription="@string/generalImgContentText"
                app:layout_constraintBottom_toBottomOf="@id/orgName"
                app:layout_constraintStart_toEndOf="@id/orgName"
                app:layout_constraintTop_toTopOf="@id/orgName" />

            <TextView
                android:id="@+id/repoName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen8dp"
                android:textAppearance="?attr/textAppearanceTitleLarge"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/imageAvatar" />

            <TextView
                android:id="@+id/repoDescription"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen4dp"
                android:alpha="0.7"
                android:ellipsize="end"
                android:maxLines="2"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/repoName" />

            <LinearLayout
                android:id="@+id/metaLayout"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/repoDescription">

                <ImageView
                    android:id="@+id/repo_language_frame"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    android:layout_marginEnd="@dimen/dimen12dp"
                    android:contentDescription="@string/generalImgContentText" />

                <ImageView
                    android:id="@+id/starIcon"
                    android:layout_width="@dimen/dimen16dp"
                    android:layout_height="@dimen/dimen16dp"
                    android:contentDescription="@string/generalImgContentText"
                    app:srcCompat="@drawable/ic_star"
                    app:tint="?attr/iconsColor" />

                <TextView
                    android:id="@+id/repoStars"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/dimen4dp"
                    android:layout_marginEnd="@dimen/dimen16dp"
                    android:textAppearance="?attr/textAppearanceLabelMedium" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <ImageView
                    android:id="@+id/repoIsPrivate"
                    android:layout_width="@dimen/dimen14dp"
                    android:layout_height="@dimen/dimen14dp"
                    android:contentDescription="@string/generalImgContentText"
                    android:visibility="gone"
                    app:srcCompat="@drawable/ic_lock"
                    app:tint="?attr/iconsColor" />

            </LinearLayout>

            <CheckBox
                android:id="@+id/repoIsAdmin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:contentDescription="@string/generalImgContentText"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <View
                android:id="@+id/spacerView"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/metaLayout" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.listitem.ListItemCardView>

</com.google.android.material.listitem.ListItemLayout>
