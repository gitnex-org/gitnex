<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/primaryBackgroundColor">

    <com.google.android.material.loadingindicator.LoadingIndicator
        android:id="@+id/expressive_loader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        app:indicatorSize="@dimen/dimen48dp"
        app:trackThickness="@dimen/dimen4dp" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/detailScrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/main_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="@dimen/dimen12dp">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/mainProfileCard"
                style="?attr/materialCardViewFilledStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="@dimen/dimen28dp"
                android:backgroundTint="?attr/materialCardBackgroundColor"
                app:cardElevation="@dimen/dimen0dp"
                app:layout_constraintTop_toTopOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="@dimen/dimen24dp"
                    android:clipChildren="false"
                    android:clipToPadding="false">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/avatarContainer"
                        android:layout_width="@dimen/dimen120dp"
                        android:layout_height="@dimen/dimen120dp"
                        app:cardCornerRadius="@dimen/dimen28dp"
                        app:cardElevation="@dimen/dimen0dp"
                        app:strokeWidth="@dimen/dimen0dp"
                        android:backgroundTint="@android:color/transparent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                        <ImageView
                            android:id="@+id/userAvatar"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/loader_animated"
                            android:contentDescription="@string/generalImgContentText" />

                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/update_avatar"
                        android:layout_width="@dimen/dimen28dp"
                        android:layout_height="@dimen/dimen28dp"
                        app:cardBackgroundColor="?attr/colorSurfaceContainerHigh"
                        app:cardCornerRadius="@dimen/dimen8dp"
                        app:cardElevation="@dimen/dimen0dp"
                        app:strokeColor="?attr/colorOutlineVariant"
                        app:strokeWidth="@dimen/dimen1dp"
                        app:layout_constraintTop_toTopOf="@id/avatarContainer"
                        app:layout_constraintBottom_toBottomOf="@id/avatarContainer"
                        app:layout_constraintStart_toStartOf="@id/avatarContainer"
                        app:layout_constraintEnd_toEndOf="@id/avatarContainer"
                        app:layout_constraintHorizontal_bias="1.05"
                        app:layout_constraintVertical_bias="1.05">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="@string/generalImgContentText"
                            android:padding="@dimen/dimen6dp"
                            android:src="@drawable/ic_edit"
                            app:tint="?attr/colorPrimary" />

                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/update_profile"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/editSettings"
                        android:visibility="gone"
                        app:icon="@drawable/ic_edit"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/follow_user"
                        style="@style/Widget.Material3.Button.IconButton.Filled"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/userFollow"
                        app:iconPadding="@dimen/dimen8dp"
                        android:visibility="gone"
                        app:icon="@drawable/ic_person_add"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/update_profile" />

                    <TextView
                        android:id="@+id/userFullName"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/dimen16dp"
                        android:textAppearance="?attr/textAppearanceHeadlineMedium"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/avatarContainer" />

                    <TextView
                        android:id="@+id/userLogin"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="?attr/colorPrimary"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/userFullName" />

                    <TextView
                        android:id="@+id/bio"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/dimen12dp"
                        android:textAppearance="?attr/textAppearanceBodyLarge"
                        app:layout_constraintTop_toBottomOf="@id/userLogin" />

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/statsContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/dimen28dp"
                        app:layout_constraintTop_toBottomOf="@id/bio">

                        <include
                            android:id="@+id/user_followers_count_layout"
                            layout="@layout/item_profile_stat"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toStartOf="@id/user_following_count_layout"
                            app:layout_constraintHorizontal_chainStyle="spread" />

                        <include
                            android:id="@+id/user_following_count_layout"
                            layout="@layout/item_profile_stat"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintStart_toEndOf="@id/user_followers_count_layout"
                            app:layout_constraintEnd_toStartOf="@id/user_stars_layout" />

                        <include
                            android:id="@+id/user_stars_layout"
                            layout="@layout/item_profile_stat"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintStart_toEndOf="@id/user_following_count_layout"
                            app:layout_constraintEnd_toEndOf="parent" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>

            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/infoCard"
                style="?attr/materialCardViewFilledStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen12dp"
                android:backgroundTint="?attr/materialCardBackgroundColor"
                app:cardCornerRadius="@dimen/dimen28dp"
                app:cardElevation="@dimen/dimen0dp"
                app:layout_constraintTop_toBottomOf="@id/mainProfileCard">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="@dimen/dimen24dp">

                    <include
                        android:id="@+id/layout_email"
                        layout="@layout/item_profile_info"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:layout_constraintTop_toTopOf="parent" />

                    <include
                        android:id="@+id/layout_website"
                        layout="@layout/item_profile_info"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:layout_constraintTop_toBottomOf="@id/layout_email" />

                    <include
                        android:id="@+id/layout_location"
                        layout="@layout/item_profile_info"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/layout_website" />

                    <include
                        android:id="@+id/layout_lang"
                        layout="@layout/item_profile_info"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/layout_location" />

                    <include
                        android:id="@+id/layout_joined"
                        layout="@layout/item_profile_info"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/layout_lang" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/heatmapCard"
                style="?attr/materialCardViewFilledStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen12dp"
                android:backgroundTint="?attr/materialCardBackgroundColor"
                android:visibility="gone"
                app:cardCornerRadius="@dimen/dimen28dp"
                app:layout_constraintTop_toBottomOf="@id/infoCard">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/dimen24dp">

                    <TextView
                        style="?attr/textAppearanceTitleMedium"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/dimen16dp"
                        android:text="@string/contributions"
                        android:textStyle="bold" />

                    <GridView
                        android:id="@+id/heatmapGrid"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/dimen144dp"
                        android:numColumns="12"
                        android:verticalSpacing="@dimen/dimen6dp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/profile_repo_view"
                style="?attr/materialCardViewFilledStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen12dp"
                android:backgroundTint="?attr/materialCardBackgroundColor"
                android:visibility="gone"
                app:cardCornerRadius="@dimen/dimen28dp"
                app:layout_constraintTop_toBottomOf="@id/heatmapCard">

                <TextView
                    android:id="@+id/profile_repo_content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="@dimen/dimen24dp"
                    android:textAppearance="?attr/textAppearanceBodyMedium" />

            </com.google.android.material.card.MaterialCardView>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.core.widget.NestedScrollView>

</FrameLayout>
