<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <com.google.android.material.bottomsheet.BottomSheetDragHandleView
        android:id="@+id/drag_handle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constrainedHeight="true"
        app:layout_constraintTop_toBottomOf="@id/drag_handle"
        app:layout_constraintBottom_toBottomOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="@dimen/dimen32dp"
            android:paddingHorizontal="@dimen/dimen24dp">

            <TextView
                android:id="@+id/title"
                style="@style/TextAppearance.Material3.HeadlineSmall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/search"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnClear"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/reset"
                app:layout_constraintBottom_toBottomOf="@id/title"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/title" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/searchQueryLayout"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen16dp"
                android:hint="@string/search"
                app:endIconMode="clear_text"
                app:layout_constraintTop_toBottomOf="@id/title"
                app:shapeAppearance="@style/ShapeAppearance.Material3.Corner.Medium">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/searchQueryEdit"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:imeOptions="actionSearch" />

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/filterChipGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen16dp"
                app:chipSpacingHorizontal="@dimen/dimen8dp"
                app:layout_constraintTop_toBottomOf="@id/searchQueryLayout">

                <com.google.android.material.chip.Chip
                    android:id="@+id/includeTopicChip"
                    style="@style/CustomChipFilter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/exploreFilterIncludeTopic"
                    android:checkable="true" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/includeDescChip"
                    style="@style/CustomChipFilter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/exploreFilterIncludeDesc"
                    android:checkable="true" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/includeTemplateChip"
                    style="@style/CustomChipFilter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/exploreFilterIncludeTemplateRepos"
                    android:checkable="true" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/onlyArchivedChip"
                    style="@style/CustomChipFilter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/exploreFilterIncludeArchive"
                    android:checkable="true" />

            </com.google.android.material.chip.ChipGroup>

            <TextView
                android:id="@+id/sortTitle"
                style="@style/TextAppearance.Material3.BodyLarge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen24dp"
                android:text="@string/sort"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/filterChipGroup" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/sortChipGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen8dp"
                app:chipSpacingHorizontal="@dimen/dimen8dp"
                app:singleSelection="true"
                app:selectionRequired="true"
                app:layout_constraintTop_toBottomOf="@id/sortTitle">

                <com.google.android.material.chip.Chip
                    android:id="@+id/sortCreated"
                    style="@style/CustomChipFilter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/created"
                    android:checkable="true" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/sortUpdated"
                    style="@style/CustomChipFilter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/updated"
                    android:checkable="true" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/sortStars"
                    style="@style/CustomChipFilter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/stars"
                    android:checkable="true" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/sortForks"
                    style="@style/CustomChipFilter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/forks"
                    android:checkable="true" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/sortSize"
                    style="@style/CustomChipFilter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/size"
                    android:checkable="true" />

            </com.google.android.material.chip.ChipGroup>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnApply"
                style="@style/Widget.Material3.Button"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dimen56dp"
                android:layout_marginTop="@dimen/dimen24dp"
                app:cornerRadius="@dimen/dimen32dp"
                android:text="@string/search"
                app:layout_constraintTop_toBottomOf="@id/sortChipGroup" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
