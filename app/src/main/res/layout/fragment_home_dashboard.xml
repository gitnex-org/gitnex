<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/primaryBackgroundColor"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="@dimen/dimen16dp"
            android:paddingTop="@dimen/dimen20dp"
            android:paddingBottom="@dimen/dimen32dp">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/avatarContainer"
                android:layout_width="@dimen/dimen48dp"
                android:layout_height="@dimen/dimen48dp"
                app:cardCornerRadius="@dimen/dimen12dp"
                app:cardElevation="0dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                android:backgroundTint="@android:color/transparent"
                app:strokeWidth="0dp">

                <ImageView
                    android:id="@+id/userAvatar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@string/generalImgContentText"
                    android:scaleType="centerCrop"
                    android:src="@drawable/loader_animated" />

            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/dimen12dp"
                android:orientation="vertical"
                android:gravity="center_vertical"
                app:layout_constraintBottom_toBottomOf="@id/avatarContainer"
                app:layout_constraintEnd_toStartOf="@+id/settingsCard"
                app:layout_constraintStart_toEndOf="@id/avatarContainer"
                app:layout_constraintTop_toTopOf="@id/avatarContainer">

                <TextView
                    android:id="@+id/userFullname"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.Material3.TitleLarge"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/userEmail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
                    android:alpha="0.7" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dimen4dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/userFollowers"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                        android:textStyle="bold"
                        android:textColor="?attr/iconsColor" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/dimen4dp"
                        android:text="@string/profileTabFollowers"
                        android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                        android:alpha="0.6" />

                    <View
                        android:layout_width="1dp"
                        android:layout_height="@dimen/dimen8dp"
                        android:layout_marginHorizontal="@dimen/dimen8dp"
                        android:background="?android:attr/dividerVertical" />

                    <TextView
                        android:id="@+id/userFollowing"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                        android:textStyle="bold"
                        android:textColor="?attr/iconsColor" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/dimen4dp"
                        android:text="@string/profileTabFollowing"
                        android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                        android:alpha="0.6" />

                </LinearLayout>

            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/settingsCard"
                android:layout_width="@dimen/dimen40dp"
                android:layout_height="@dimen/dimen40dp"
                app:cardBackgroundColor="?attr/materialCardBackgroundColor"
                app:cardCornerRadius="@dimen/dimen12dp"
                app:cardElevation="0dp"
                app:layout_constraintBottom_toBottomOf="@id/avatarContainer"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/avatarContainer"
                app:strokeWidth="0dp">

                <ImageView
                    android:layout_width="@dimen/dimen24dp"
                    android:layout_height="@dimen/dimen24dp"
                    android:layout_gravity="center"
                    android:contentDescription="@string/generalImgContentText"
                    android:src="@drawable/ic_settings"
                    app:tint="?attr/iconsColor" />

            </com.google.android.material.card.MaterialCardView>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:cardBackgroundColor="?attr/materialCardBackgroundColor"
            app:cardElevation="0dp"
            app:shapeAppearance="@style/ShapeAppearance.TopRounded"
            app:strokeWidth="0dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="@dimen/dimen8dp"
                android:paddingVertical="@dimen/dimen20dp">

                <TextView
                    android:id="@+id/greetingText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:textAppearance="@style/TextAppearance.Material3.TitleLarge"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="@id/actionButtonsContainer"
                    app:layout_constraintEnd_toStartOf="@id/actionButtonsContainer"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@id/actionButtonsContainer" />

                <LinearLayout
                    android:id="@+id/actionButtonsContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/dimen4dp"
                    android:orientation="horizontal"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="@dimen/dimen40dp"
                        android:layout_height="@dimen/dimen40dp"
                        android:layout_marginEnd="@dimen/dimen8dp"
                        app:cardBackgroundColor="?attr/primaryBackgroundColor"
                        app:cardCornerRadius="@dimen/dimen12dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">

                        <ImageView
                            android:id="@+id/serverIcon"
                            android:layout_width="@dimen/dimen24dp"
                            android:layout_height="@dimen/dimen24dp"
                            android:layout_gravity="center"
                            android:contentDescription="@string/generalImgContentText"
                            android:src="@drawable/ic_info"
                            app:tint="?attr/iconsColor" />

                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="@dimen/dimen40dp"
                        android:layout_height="@dimen/dimen40dp"
                        app:cardBackgroundColor="?attr/primaryBackgroundColor"
                        app:cardCornerRadius="@dimen/dimen12dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">

                        <ImageView
                            android:id="@+id/refreshButton"
                            android:layout_width="@dimen/dimen24dp"
                            android:layout_height="@dimen/dimen24dp"
                            android:layout_gravity="center"
                            android:contentDescription="@string/generalImgContentText"
                            android:src="@drawable/ic_refresh"
                            app:tint="?attr/iconsColor" />

                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/largeCardsRow1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dimen24dp"
                    android:orientation="horizontal"
                    android:baselineAligned="false"
                    app:layout_constraintTop_toBottomOf="@id/actionButtonsContainer">

                    <include
                        android:id="@+id/repoStarredCard"
                        layout="@layout/item_dashboard_card_large"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginEnd="@dimen/dimen4dp"
                        android:layout_weight="1" />

                    <include
                        android:id="@+id/repoWatchedCard"
                        layout="@layout/item_dashboard_card_large"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="@dimen/dimen4dp"
                        android:layout_weight="1" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/largeCardsRow2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dimen12dp"
                    android:orientation="horizontal"
                    android:baselineAligned="false"
                    app:layout_constraintTop_toBottomOf="@id/largeCardsRow1">

                    <include
                        android:id="@+id/myReposCard"
                        layout="@layout/item_dashboard_card_large"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginEnd="@dimen/dimen4dp"
                        android:layout_weight="1" />

                    <include
                        android:id="@+id/myIssuesCard"
                        layout="@layout/item_dashboard_card_large"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="@dimen/dimen4dp"
                        android:layout_weight="1" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/largeCardsRow3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dimen12dp"
                    android:orientation="horizontal"
                    android:baselineAligned="false"
                    app:layout_constraintTop_toBottomOf="@id/largeCardsRow2">

                    <include
                        android:id="@+id/organizationsCard"
                        layout="@layout/item_dashboard_card_large"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginEnd="@dimen/dimen4dp"
                        android:layout_weight="1" />

                    <include
                        android:id="@+id/activitiesCard"
                        layout="@layout/item_dashboard_card_large"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="@dimen/dimen4dp"
                        android:layout_weight="1" />

                </LinearLayout>

                <include
                    android:id="@+id/mostVisitedReposCard"
                    layout="@layout/item_dashboard_card_full"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dimen12dp"
                    android:layout_marginHorizontal="@dimen/dimen4dp"
                    app:layout_constraintTop_toBottomOf="@id/largeCardsRow3"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <include
                    android:id="@+id/notesCard"
                    layout="@layout/item_dashboard_card_full"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dimen12dp"
                    android:layout_marginHorizontal="@dimen/dimen4dp"
                    app:layout_constraintTop_toBottomOf="@id/mostVisitedReposCard"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <LinearLayout
                    android:id="@+id/largeCardsRow6"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dimen12dp"
                    android:orientation="horizontal"
                    android:baselineAligned="false"
                    app:layout_constraintTop_toBottomOf="@id/notesCard">

                    <include
                        android:id="@+id/accountSettingsCard"
                        layout="@layout/item_dashboard_card_large"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginEnd="@dimen/dimen4dp"
                        android:layout_weight="1" />

                    <include
                        android:id="@+id/instanceAdministrationCard"
                        layout="@layout/item_dashboard_card_large"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="@dimen/dimen4dp"
                        android:layout_weight="1" />

                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/userAccountsRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/dimen16dp"
                android:layout_marginBottom="@dimen/dimen16dp"
                android:clipToPadding="false"
                android:visibility="gone"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
