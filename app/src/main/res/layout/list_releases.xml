<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.listitem.ListItemLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <com.google.android.material.listitem.ListItemCardView
        android:id="@+id/card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:checkable="false"
        android:layout_marginVertical="@dimen/dimen1dp"
        app:strokeWidth="0dp"
        app:cardBackgroundColor="?attr/materialCardBackgroundColor">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="@dimen/dimen8dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/headerCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:id="@+id/releaseName"
                    style="@style/TextAppearance.Material3.TitleLarge"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/dimen8dp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="?attr/colorOnSurface"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toStartOf="@+id/releasesOptionsMenu"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/releasesOptionsMenu"
                    style="@style/Widget.Material3.Button.IconButton"
                    android:layout_width="@dimen/dimen52dp"
                    android:layout_height="@dimen/dimen52dp"
                    android:padding="0dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:insetLeft="0dp"
                    android:insetRight="0dp"
                    app:icon="@drawable/ic_dotted_menu"
                    app:iconSize="@dimen/dimen26dp"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp"
                    app:iconTint="?attr/iconsColor"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <ImageView
                    android:id="@+id/releaseTypeBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dimen8dp"
                    android:adjustViewBounds="true"
                    android:contentDescription="@string/generalImgContentText"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/releaseName" />

                <LinearLayout
                    android:id="@+id/metaRow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/dimen12dp"
                    android:gravity="center_vertical"
                    app:layout_constraintBottom_toBottomOf="@id/releaseTypeBadge"
                    app:layout_constraintStart_toEndOf="@id/releaseTypeBadge"
                    app:layout_constraintTop_toTopOf="@id/releaseTypeBadge">

                    <ImageView
                        android:layout_width="@dimen/dimen18dp"
                        android:layout_height="@dimen/dimen18dp"
                        android:contentDescription="@string/generalImgContentText"
                        app:srcCompat="@drawable/ic_tag"
                        app:tint="?attr/colorPrimary" />

                    <TextView
                        android:id="@+id/releaseTag"
                        style="@style/TextAppearance.Material3.LabelLarge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/dimen4dp"
                        android:textColor="?attr/colorOnSurfaceVariant" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="@dimen/dimen8dp"
                        android:text="@string/dot"
                        android:textColor="?attr/colorOutlineVariant" />

                    <TextView
                        android:id="@+id/releaseDate"
                        style="@style/TextAppearance.Material3.LabelLarge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="?attr/colorOnSurfaceVariant" />

                </LinearLayout>

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/authorAvatar"
                    android:layout_width="@dimen/dimen24dp"
                    android:layout_height="@dimen/dimen24dp"
                    android:layout_marginTop="@dimen/dimen12dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/releaseTypeBadge"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Small" />

                <TextView
                    android:id="@+id/authorName"
                    style="@style/TextAppearance.Material3.LabelMedium"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/dimen8dp"
                    android:alpha="0.8"
                    app:layout_constraintBottom_toBottomOf="@id/authorAvatar"
                    app:layout_constraintStart_toEndOf="@id/authorAvatar"
                    app:layout_constraintTop_toTopOf="@id/authorAvatar" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <TextView
                android:id="@+id/releaseBodyContent"
                style="@style/TextAppearance.Material3.BodyMedium"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="@dimen/dimen20dp"
                android:paddingBottom="@dimen/dimen16dp"
                android:lineSpacingExtra="@dimen/dimen2dp"
                android:textColor="?attr/colorOnSurface"
                app:layout_constraintTop_toBottomOf="@id/headerCard" />

            <LinearLayout
                android:id="@+id/btnAssets"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingVertical="@dimen/dimen12dp"
                app:layout_constraintTop_toBottomOf="@id/releaseBodyContent"
                tools:ignore="UseCompoundDrawables">

                <TextView
                    style="@style/TextAppearance.Material3.TitleMedium"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/releaseDownloadText"
                    android:textColor="?attr/colorPrimary"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/imgExpand"
                    android:layout_width="@dimen/dimen20dp"
                    android:layout_height="@dimen/dimen20dp"
                    android:contentDescription="@string/generalImgContentText"
                    app:srcCompat="@drawable/ic_chevron_right"
                    app:tint="?attr/colorPrimary" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/downloadsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="@dimen/dimen16dp"
                android:visibility="gone"
                android:animateLayoutChanges="true"
                app:layout_constraintTop_toBottomOf="@id/btnAssets">

                <include
                    android:id="@+id/sourceZipLayout"
                    layout="@layout/list_releases_downloads" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/downloadList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false" />

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.listitem.ListItemCardView>

</com.google.android.material.listitem.ListItemLayout>
